    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy", // debugpy
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "args": [ 
                //"nor_qa", "codex", "hotpotqa", "write"
                
            "write", "nor_qa_codex_hotpotqa", "--instantiation_scheme", "nor_qa", "--prompt_set", "1", "--no_diff"    
            ]
        }
    ]
}